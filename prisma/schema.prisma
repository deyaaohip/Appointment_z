generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== TENANT & SUBSCRIPTION ====================

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  businessType String  @default("general")
  domain      String?
  logo        String?
  primaryColor String  @default("#6366f1")
  secondaryColor String @default("#8b5cf6")
  timezone    String   @default("UTC")
  currency    String   @default("USD")
  language    String   @default("en")
  theme       String   @default("light")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isActive])

  subscription    TenantSubscription?
  branches        Branch[]
  users           TenantUser[]
  roles           Role[]
  serviceCategories ServiceCategory[]
  employees       Employee[]
  customers       Customer[]
  bookings        Booking[]
  payments        Payment[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  coupons         Coupon[]
  waitlistEntries WaitlistEntry[]
  employeeSchedules EmployeeSchedule[]
  employeeLeaves  EmployeeLeave[]
  customerNotes   CustomerNote[]
  employeeServices EmployeeService[]
  services        Service[]
  whatsappConfigs  WhatsAppConfig[]
  whatsappTemplates WhatsAppTemplate[]
  whatsappLogs    WhatsAppReminderLog[]
}

// ==================== WHATSAPP ====================

model WhatsAppConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  isEnabled       Boolean  @default(false)
  providerName    String   @default("meta")
  apiUrl          String   @default("")
  accessToken      String   @default("")
  phoneNumberId   String   @default("")
  businessNumber  String   @default("")
  webhookUrl      String?
  defaultTemplateId String?
  autoReminders   Boolean  @default(false)
  reminderSchedule String  @default("[24,3]")
  retryCount      Int      @default(2)
  dailyLimit      Int      @default(500)
  duplicateWindowMinutes Int @default(60)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs      WhatsAppReminderLog[]
}

model WhatsAppTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  body            String
  isDefault       Boolean  @default(false)
  category        String   @default("reminder")
  language        String   @default("ar")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs      WhatsAppReminderLog[]
}

model WhatsAppReminderLog {
  id              String   @id @default(cuid())
  tenantId        String
  bookingId       String?
  customerId      String?
  templateId      String?
  configId        String?
  customerName    String?
  phoneNumber     String
  message         String
  status          String   @default("pending")
  deliveryStatus  String?
  readStatus      String?
  errorMessage    String?
  whatsappMessageId String?
  initiatedBy     String   @default("system")
  retryAttempt    Int      @default(0)
  scheduledFor    DateTime?
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([bookingId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template WhatsAppTemplate?    @relation(fields: [templateId], references: [id])
  config   WhatsAppConfig?     @relation(fields: [configId], references: [id])
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  price         Float    @default(0)
  interval      String   @default("monthly")
  maxUsers      Int      @default(1)
  maxEmployees  Int      @default(1)
  maxBranches   Int      @default(1)
  maxBookings   Int      @default(100)
  maxServices   Int      @default(10)
  maxStorage    Int      @default(100)
  hasSms        Boolean  @default(false)
  hasWhatsapp   Boolean  @default(false)
  hasCalendarSync Boolean @default(false)
  hasReports    Boolean  @default(false)
  hasApiAccess  Boolean  @default(false)
  hasIntegrations Boolean @default(false)
  hasWhiteLabel Boolean  @default(false)
  hasCustomDomain Boolean @default(false)
  features      String   @default("[]")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  planId          String
  status          String   @default("active")
  startDate       DateTime @default(now())
  endDate         DateTime
  trialEndsAt     DateTime?
  lastBilledAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan  @relation(fields: [planId], references: [id])
}

// ==================== RBAC ====================

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  permissions String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  TenantUser[]
}

model TenantUser {
  id            String   @id @default(cuid())
  tenantId      String
  roleId        String
  email         String
  name          String
  avatar        String?
  phone         String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([isActive])

  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role             Role       @relation(fields: [roleId], references: [id])
  assignedBookings Booking[]  @relation("EmployeeBooking")
  auditLogs        AuditLog[]
}

// ==================== BRANCHES ====================

model Branch {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  address     String?
  city        String?
  country     String?
  phone       String?
  email       String?
  timezone    String   @default("UTC")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]
  bookings  Booking[]
  employeeSchedules EmployeeSchedule[]
}

// ==================== EMPLOYEES ====================

model Employee {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String
  name            String
  email           String?
  phone           String?
  avatar          String?
  bio             String?
  specialization  String?
  commissionRate  Float    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([branchId])

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch            @relation(fields: [branchId], references: [id])
  schedules        EmployeeSchedule[]
  services         EmployeeService[]
  leaves           EmployeeLeave[]
}

model EmployeeSchedule {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  branchId    String
  dayOfWeek   Int
  startTime   String
  endTime     String
  breakStart  String?
  breakEnd    String?
  isWorking   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
}

model EmployeeLeave {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      String   @default("approved")
  createdAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])
}

// ==================== CUSTOMERS ====================

model Customer {
  id              String   @id @default(cuid())
  tenantId        String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  avatar          String?
  dateOfBirth     DateTime?
  gender          String?
  address         String?
  city            String?
  country         String?
  notes           String?
  tags            String   @default("[]")
  loyaltyPoints   Int      @default(0)
  membershipTier  String   @default("regular")
  isBlacklisted   Boolean  @default(false)
  portalAccess    Boolean  @default(false)
  source          String   @default("direct")
  customFields    String   @default("{}")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([email])
  @@index([phone])

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  payments        Payment[]
  customerNotes   CustomerNote[]
  waitlistEntries WaitlistEntry[]
}

model CustomerNote {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String
  content     String
  createdBy   String
  createdAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ==================== SERVICES ====================

model ServiceCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services Service[]
}

model Service {
  id              String   @id @default(cuid())
  tenantId        String
  categoryId      String
  name            String
  description     String?
  duration        Int      @default(30)
  bufferBefore    Int      @default(0)
  bufferAfter     Int      @default(0)
  price           Float    @default(0)
  variablePrice   Boolean  @default(false)
  minPrice        Float?
  maxPrice        Float?
  image           String?
  isActive        Boolean  @default(true)
  maxCapacity     Int      @default(1)
  isGroupBooking  Boolean  @default(false)
  requireDeposit  Boolean  @default(false)
  depositAmount   Float?
  customFields    String   @default("[]")
  taxRate         Float    @default(0)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, categoryId])

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  bookings   BookingService[]
  employees  EmployeeService[]
}

model EmployeeService {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  serviceId   String
  canPerform  Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([serviceId])

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

// ==================== BOOKINGS ====================

model Booking {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String
  customerId      String
  employeeId      String?
  status          String   @default("pending")
  type            String   @default("single")

  @@index([tenantId, status])
  @@index([tenantId, startDate])
  @@index([branchId])
  @@index([customerId])
  @@index([employeeId])
  @@index([tenantId, createdAt])

  startDate       DateTime
  endDate         DateTime
  startTime       String
  endTime         String
  notes           String?
  internalNotes   String?
  source          String   @default("online")
  totalPrice      Float    @default(0)
  depositAmount   Float    @default(0)
  paidAmount      Float    @default(0)
  discountAmount  Float    @default(0)
  taxAmount       Float    @default(0)
  tipAmount       Float    @default(0)
  isRecurring     Boolean  @default(false)
  recurringPattern String?
  parentBookingId String?
  noShowCount     Int      @default(0)
  reminderSent    Boolean  @default(false)
  confirmationSent Boolean @default(false)
  customFieldValues String @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  employee       TenantUser?     @relation("EmployeeBooking", fields: [employeeId], references: [id])
  parent         Booking?        @relation("BookingChildren", fields: [parentBookingId], references: [id])
  children       Booking[]       @relation("BookingChildren")
  services       BookingService[]
  payments       Payment[]
  waitlistEntry  WaitlistEntry?
}

model BookingService {
  id          String   @id @default(cuid())
  bookingId   String
  serviceId   String
  price       Float
  duration    Int
  quantity    Int      @default(1)
  employeeId  String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])
}

model WaitlistEntry {
  id             String   @id @default(cuid())
  tenantId       String
  customerId     String
  serviceId      String
  branchId       String
  preferredDate  String?
  preferredTime  String?
  status         String   @default("waiting")
  bookingId      String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])
}

// ==================== PAYMENTS ====================

model Payment {
  id             String   @id @default(cuid())
  tenantId       String
  bookingId      String
  customerId     String?
  amount         Float
  method         String   @default("cash")
  status         String   @default("pending")
  currency       String   @default("USD")

  @@index([tenantId, status])
  @@index([bookingId])
  @@index([createdAt])

  transactionId  String?
  couponId       String?
  giftCardCode   String?
  walletUsed     Boolean  @default(false)
  walletAmount   Float    @default(0)
  refundedAmount Float    @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
  coupon   Coupon?  @relation(fields: [couponId], references: [id])
}

model Coupon {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  type        String   @default("percentage")
  value       Float
  minPurchase Float?
  maxUses     Int?
  usedCount   Int      @default(0)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([tenantId, code])

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments Payment[]
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  customerId  String?
  title       String
  message     String
  type        String   @default("info")
  channel     String   @default("in_app")
  isRead      Boolean  @default(false)
  relatedId   String?
  relatedType String?
  createdAt   DateTime @default(now())

  @@index([tenantId, userId])
  @@index([tenantId, isRead])

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  action      String
  entity      String
  entityId    String?
  details     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   TenantUser @relation(fields: [userId], references: [id])
}